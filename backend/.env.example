# If MONGODB_URI is left blank, the server auto-starts an in-memory MongoDB
# instance so you can run the whole project with zero DB setup (great for
# hackathon judging). For a real deployment, set it to your Atlas URI:
MONGODB_URI=

PORT=5000

# Comma separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# Optional PIN for the zero-config "default" clinic (served at
# /c/default/reception, which is what the old /reception link redirects
# to). Leave blank for no PIN on that one clinic. Every clinic created
# through the "create a clinic" page sets its own PIN independently of
# this - this only affects the pre-existing default one.
DEFAULT_RECEPTION_PIN=

